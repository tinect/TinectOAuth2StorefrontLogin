{% sw_extends '@Storefront/storefront/page/account/profile/index.html.twig' %}

{% block page_account_profile %}
    {{ parent() }}

    {% set connectedClients = tinect_oauth_connected_clients(context.context, context.customer.id) %}

    {% if connectedClients|length > 0 %}
        <div class="card tinect-oauth-connections mt-3">
            <div class="card-body">
                <div class="card-title">
                    {{ 'tinect-oauth.connect.title'|trans|sw_sanitize }}
                </div>

                <div class="row">
                    {% for client in connectedClients %}
                        <div class="col-12 col-sm-6 col-lg-4 mb-3">
                            <div class="card h-100 tinect-oauth-connection-card tinect-oauth-connection-card--{{ client.provider|escape('html_attr') }}">
                                <div class="card-body d-flex flex-column justify-content-between">
                                    <div>
                                        <strong>{{ client.name|sw_sanitize }}</strong>
                                    </div>
                                    <div class="mt-2">
                                        {% if client.connected %}
                                            <span class="badge bg-success mb-2">
                                                {{ 'tinect-oauth.connect.statusConnected'|trans|sw_sanitize }}
                                            </span>
                                            <form action="{{ path('widgets.tinect.oauth.disconnect', { clientId: client.id }) }}" method="post">
                                                <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                                                    {{ 'tinect-oauth.connect.disconnect'|trans|sw_sanitize }}
                                                </button>
                                            </form>
                                        {% else %}
                                            <span class="badge bg-secondary mb-2">
                                                {{ 'tinect-oauth.connect.statusNotConnected'|trans|sw_sanitize }}
                                            </span>
                                            <a href="{{ path('widgets.tinect.oauth.connect', { clientId: client.id }) }}"
                                               class="btn btn-sm btn-outline-secondary w-100">
                                                {{ 'tinect-oauth.connect.connect'|trans({ '%provider%': client.name })|sw_sanitize }}
                                            </a>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}
