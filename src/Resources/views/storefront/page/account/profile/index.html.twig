{% sw_extends '@Storefront/storefront/page/account/profile/index.html.twig' %}

{% block page_account_profile %}
    {{ parent() }}

    {% set connectedClients = tinect_oauth_connected_clients(context.context, context.customer.id) %}

    {% if connectedClients|length > 0 %}
        <div class="card tinect-oauth-connections mt-3">
            <div class="card-body">
                <div class="card-title">
                    {{ 'tinect-oauth.connect.title'|trans|sw_sanitize }}
                </div>

                <div class="row">
                    {% for client in connectedClients %}
                        <div class="col-12 col-sm-6 col-lg-4 mb-3">
                            <div class="card h-100 tinect-oauth-connection-card tinect-oauth-connection-card--{{ client.provider|escape('html_attr') }}">
                                <div class="card-body d-flex flex-column justify-content-between">
                                    <div>
                                        <strong>{{ client.name|sw_sanitize }}</strong>
                                    </div>
                                    <div class="mt-2">
                                        {% if client.connected %}
                                            <span class="badge bg-success mb-2">
                                                {{ 'tinect-oauth.connect.statusConnected'|trans|sw_sanitize }}
                                            </span>
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger w-100"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#tinect-oauth-disconnect-modal-{{ client.id|escape('html_attr') }}">
                                                {{ 'tinect-oauth.connect.disconnect'|trans|sw_sanitize }}
                                            </button>

                                            <div class="modal fade"
                                                 id="tinect-oauth-disconnect-modal-{{ client.id|escape('html_attr') }}"
                                                 tabindex="-1"
                                                 aria-modal="true"
                                                 role="dialog">
                                                <div class="modal-dialog">
                                                    <div class="modal-content">
                                                        <div class="modal-header">
                                                            <h5 class="modal-title">
                                                                {{ 'tinect-oauth.connect.disconnectConfirmTitle'|trans|sw_sanitize }}
                                                            </h5>
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                        </div>
                                                        <div class="modal-body">
                                                            {{ 'tinect-oauth.connect.disconnectConfirmText'|trans({ '%provider%': client.name })|sw_sanitize }}
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                                                {{ 'tinect-oauth.connect.disconnectConfirmCancel'|trans|sw_sanitize }}
                                                            </button>
                                                            <form action="{{ path('widgets.tinect.oauth.disconnect', { clientId: client.id }) }}" method="post">
                                                                <button type="submit" class="btn btn-danger">
                                                                    {{ 'tinect-oauth.connect.disconnect'|trans|sw_sanitize }}
                                                                </button>
                                                            </form>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        {% else %}
                                            <span class="badge bg-secondary mb-2">
                                                {{ 'tinect-oauth.connect.statusNotConnected'|trans|sw_sanitize }}
                                            </span>
                                            <a href="{{ path('widgets.tinect.oauth.connect', { clientId: client.id }) }}"
                                               class="btn btn-sm btn-outline-secondary w-100">
                                                {{ 'tinect-oauth.connect.connect'|trans({ '%provider%': client.name })|sw_sanitize }}
                                            </a>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}
